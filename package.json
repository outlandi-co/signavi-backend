{
  "name": "signavi-backend",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --config nodemon.json server.js",
    "dev:watch": "nodemon server.js --ignore uploads --ignore labels --ignore *.log --ignore *.tmp",
    "dev:debug": "nodemon --inspect server.js",
    "start": "node server.js",
    "clean": "rimraf logs tmp",
    "rebuild": "npm run clean && npm install"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.7",
    "openai": "^6.32.0",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "resend": "^6.1.3",
    "socket.io": "^4.8.3",
    "square": "^44.0.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "rimraf": "^6.0.1"
  }
}
